#!/usr/bin/env node

/**
 * ACE CLI — Agent-powered Code Engine
 *
 * Usage:
 *   ace start                  — 대화형 세팅 가이드
 *   ace init [--pack dev|biz] [--stack nextjs-fastapi-pg|...] [--mode solo|team]
 *
 * 프로젝트 디렉토리에서 실행하면:
 * 1. .ace/profile.yaml 생성
 * 2. .claude/ 디렉토리에 스킬/에이전트/훅/규칙 심볼릭 링크 또는 복사
 * 3. workspace/tasks/ 디렉토리 생성
 */

const fs = require('fs')
const path = require('path')
const readline = require('readline')

const ACE_ROOT = path.resolve(__dirname)
const CWD = process.cwd()

// ─────────────────────────────────────────────
// CLI 파싱
// ─────────────────────────────────────────────

const args = process.argv.slice(2)
const command = args[0]

function getArg(name, defaultValue) {
  const idx = args.indexOf(`--${name}`)
  if (idx === -1 || idx + 1 >= args.length) return defaultValue
  return args[idx + 1]
}

// ─────────────────────────────────────────────
// init 명령
// ─────────────────────────────────────────────

function init() {
  const pack = getArg('pack', 'dev')
  const stack = getArg('stack', 'nextjs-fastapi-pg')
  const mode = getArg('mode', 'solo')
  const projectName = path.basename(CWD)

  console.log(`\n🔧 ACE init — ${projectName}`)
  console.log(`   pack: ${pack}, stack: ${stack}, mode: ${mode}\n`)

  // 1. .ace/ 디렉토리 생성
  const aceDir = path.join(CWD, '.ace')
  mkdirSafe(aceDir)

  // 2. profile.yaml 생성
  const profilePath = path.join(aceDir, 'profile.yaml')
  if (fs.existsSync(profilePath)) {
    console.log('   ⚠ profile.yaml already exists, skipping')
  } else {
    const profile = generateProfile(projectName, pack, stack, mode)
    fs.writeFileSync(profilePath, profile, 'utf-8')
    console.log('   ✓ .ace/profile.yaml created')
  }

  // 3. workspace/ 구조 생성
  mkdirSafe(path.join(CWD, 'workspace'))
  mkdirSafe(path.join(CWD, 'workspace', 'tasks'))
  const taskIndexPath = path.join(CWD, 'workspace', 'tasks', 'taskIndex.json')
  if (!fs.existsSync(taskIndexPath)) {
    fs.writeFileSync(taskIndexPath, JSON.stringify({ tasks: [] }, null, 2), 'utf-8')
  }
  console.log('   ✓ workspace/tasks/ created')

  // 4. .claude/ 설정 생성
  setupClaude(pack, stack, mode)

  // 5. .gitignore 갱신
  updateGitignore()

  console.log(`\n✅ ACE initialized for ${projectName}`)
  console.log(`   Run: /ace task start <issue#> to begin\n`)
}

// ─────────────────────────────────────────────
// profile.yaml 생성
// ─────────────────────────────────────────────

function generateProfile(name, pack, stack, mode) {
  const stackParts = parseStack(stack)
  const lines = [
    `# ACE Project Profile`,
    `# Generated by: ace init`,
    ``,
    `name: ${name}`,
    `mode: ${mode}`,
    `pack: ${pack}`,
    ``,
  ]

  if (pack === 'dev') {
    lines.push(`stack:`)
    if (stackParts.backend) lines.push(`  backend: ${stackParts.backend}`)
    if (stackParts.frontend) lines.push(`  frontend: ${stackParts.frontend}`)
    if (stackParts.db) lines.push(`  db: ${stackParts.db}`)
    lines.push(``)
  }

  if (mode === 'team') {
    lines.push(`roles:`)
    lines.push(`  - DEV`)
    if (pack === 'dev') lines.push(`  - PUBL`)
    lines.push(`  - PLAN`)
    lines.push(``)
  }

  lines.push(`issue_tracker:`)
  lines.push(`  type: none  # github | linear | jira | redmine | none`)
  lines.push(`  # url: https://...`)
  lines.push(`  # api_key_env: TRACKER_API_KEY`)
  lines.push(``)

  lines.push(`# domain:`)
  lines.push(`#   terms: ./domain/terms.md`)
  lines.push(`#   docs: ./docs/`)

  return lines.join('\n') + '\n'
}

function parseStack(stack) {
  const presets = {
    'nextjs-fastapi-pg': { backend: 'fastapi', frontend: 'nextjs', db: 'postgresql' },
    'spring-vue-mssql': { backend: 'spring-boot', frontend: 'vue', db: 'mssql' },
    'react-native-expo': { frontend: 'react-native', db: 'postgresql' },
    'django-react-pg': { backend: 'django', frontend: 'react', db: 'postgresql' },
  }
  return presets[stack] || { backend: stack, frontend: 'nextjs', db: 'postgresql' }
}

// ─────────────────────────────────────────────
// .claude/ 설정 생성
// ─────────────────────────────────────────────

function setupClaude(pack, stack, mode) {
  const claudeDir = path.join(CWD, '.claude')
  mkdirSafe(claudeDir)

  // settings.json — 훅 등록
  const settingsPath = path.join(claudeDir, 'settings.json')
  if (!fs.existsSync(settingsPath)) {
    const settings = generateSettings(mode)
    fs.writeFileSync(settingsPath, JSON.stringify(settings, null, 2), 'utf-8')
    console.log('   ✓ .claude/settings.json created (hooks registered)')
  }

  // skills/ — 코어 스킬 + 팩 스킬 복사
  const skillsDir = path.join(claudeDir, 'skills')
  mkdirSafe(skillsDir)

  // core skills (ace-status 등)
  const coreSkillsDir = path.join(ACE_ROOT, 'core', 'skills')
  if (fs.existsSync(coreSkillsDir)) {
    const coreSkills = fs.readdirSync(coreSkillsDir, { withFileTypes: true })
      .filter(d => d.isDirectory())
    for (const skill of coreSkills) {
      const skillName = `ace-${skill.name}`
      const targetDir = path.join(skillsDir, skillName)
      mkdirSafe(targetDir)
      copyDirContents(path.join(coreSkillsDir, skill.name), targetDir)
    }
  }

  // pack skills
  const packSkillsDir = path.join(ACE_ROOT, 'packs', pack, 'skills')
  if (fs.existsSync(packSkillsDir)) {
    const skills = fs.readdirSync(packSkillsDir, { withFileTypes: true })
      .filter(d => d.isDirectory())
    for (const skill of skills) {
      const skillName = `ace-${skill.name}`
      const targetDir = path.join(skillsDir, skillName)
      mkdirSafe(targetDir)
      copyDirContents(path.join(packSkillsDir, skill.name), targetDir)
    }
    console.log(`   ✓ .claude/skills/ — ${skills.length} skills installed (ace-*)`)
  }

  // agents/ — 에이전트 복사
  const agentsDir = path.join(claudeDir, 'agents')
  mkdirSafe(agentsDir)

  const packAgentsDir = path.join(ACE_ROOT, 'packs', pack, 'agents')
  if (fs.existsSync(packAgentsDir)) {
    const agents = fs.readdirSync(packAgentsDir).filter(f => f.endsWith('.md'))
    for (const agent of agents) {
      fs.copyFileSync(
        path.join(packAgentsDir, agent),
        path.join(agentsDir, agent)
      )
    }
    console.log(`   ✓ .claude/agents/ — ${agents.length} agents installed`)
  }

  // rules/ — 코어 컨벤션 + 스택 컨벤션 복사
  const rulesDir = path.join(claudeDir, 'rules')
  mkdirSafe(rulesDir)

  // core 공통 컨벤션
  const coreConvs = ['conv-common.md', 'conv-security.md']
  for (const conv of coreConvs) {
    const src = path.join(ACE_ROOT, 'core', conv)
    if (fs.existsSync(src)) {
      fs.copyFileSync(src, path.join(rulesDir, conv))
    }
  }

  // 스택별 컨벤션
  if (pack === 'dev') {
    const stackDir = path.join(ACE_ROOT, 'stacks', stack)
    if (fs.existsSync(stackDir)) {
      const stackFiles = fs.readdirSync(stackDir).filter(f => f.startsWith('conv-'))
      for (const f of stackFiles) {
        fs.copyFileSync(path.join(stackDir, f), path.join(rulesDir, f))
      }
      console.log(`   ✓ .claude/rules/ — conventions installed (${stack})`)
    } else {
      console.log(`   ⚠ Stack preset '${stack}' not found, skipping conventions`)
    }
  }

  // templates/ 복사
  const aceProjectDir = path.join(CWD, '.ace')
  const templatesDir = path.join(aceProjectDir, 'templates')
  mkdirSafe(templatesDir)

  // core templates
  const coreTemplatesDir = path.join(ACE_ROOT, 'core', 'templates')
  if (fs.existsSync(coreTemplatesDir)) {
    copyDirContents(coreTemplatesDir, templatesDir)
  }

  // pack templates (biz의 경우)
  const packTemplatesDir = path.join(ACE_ROOT, 'packs', pack, 'templates')
  if (fs.existsSync(packTemplatesDir)) {
    copyDirContents(packTemplatesDir, templatesDir)
  }
  console.log('   ✓ .ace/templates/ — artifact templates installed')
}

function generateSettings(mode) {
  const settings = {
    hooks: {}
  }

  // PostToolUse — 항상 활성
  // 참고: 실제 훅 스크립트는 .ace/hooks/에 위치
  // 현재는 스캐폴딩만 — 3단계에서 JS 구현

  return settings
}

// ─────────────────────────────────────────────
// .gitignore 갱신
// ─────────────────────────────────────────────

function updateGitignore() {
  const gitignorePath = path.join(CWD, '.gitignore')
  const aceEntries = [
    '',
    '# ACE (개인 분석 산출물 — 코드 레포에 포함하지 않음)',
    'workspace/',
    '.ace/',
  ]

  if (fs.existsSync(gitignorePath)) {
    const content = fs.readFileSync(gitignorePath, 'utf-8')
    if (content.includes('# ACE')) return // 이미 있음
    fs.appendFileSync(gitignorePath, aceEntries.join('\n') + '\n', 'utf-8')
  } else {
    fs.writeFileSync(gitignorePath, aceEntries.join('\n') + '\n', 'utf-8')
  }
  console.log('   ✓ .gitignore updated')
}

// ─────────────────────────────────────────────
// 유틸리티
// ─────────────────────────────────────────────

function mkdirSafe(dir) {
  if (!fs.existsSync(dir)) {
    fs.mkdirSync(dir, { recursive: true })
  }
}

function aceDir(cwd) {
  return path.join(cwd, '.ace')
}

function copyDirContents(src, dest) {
  if (!fs.existsSync(src)) return
  const entries = fs.readdirSync(src, { withFileTypes: true })
  for (const entry of entries) {
    const srcPath = path.join(src, entry.name)
    const destPath = path.join(dest, entry.name)
    if (entry.isDirectory()) {
      mkdirSafe(destPath)
      copyDirContents(srcPath, destPath)
    } else {
      fs.copyFileSync(srcPath, destPath)
    }
  }
}

// ─────────────────────────────────────────────
// add-pack 명령 — 기존 설치에 팩 추가
// ─────────────────────────────────────────────

function addPack() {
  const pack = args[1]
  if (!pack || !['dev', 'biz'].includes(pack)) {
    console.log('\nUsage: ace add-pack <dev|biz>\n')
    console.log('기존 스킬을 유지하면서 추가 팩의 스킬/에이전트를 설치합니다.')
    process.exit(1)
  }

  const projectName = path.basename(CWD)
  console.log(`\n📦 ACE add-pack — ${projectName} + ${pack}\n`)

  const claudeDir = path.join(CWD, '.claude')
  if (!fs.existsSync(claudeDir)) {
    console.log('❌ .claude/ 디렉토리가 없습니다. 먼저 ace init을 실행하세요.')
    process.exit(1)
  }

  // skills 추가
  const skillsDir = path.join(claudeDir, 'skills')
  const packSkillsDir = path.join(ACE_ROOT, 'packs', pack, 'skills')
  if (fs.existsSync(packSkillsDir)) {
    const skills = fs.readdirSync(packSkillsDir, { withFileTypes: true })
      .filter(d => d.isDirectory())
    for (const skill of skills) {
      const skillName = `ace-${skill.name}`
      const targetDir = path.join(skillsDir, skillName)
      mkdirSafe(targetDir)
      copyDirContents(path.join(packSkillsDir, skill.name), targetDir)
    }
    console.log(`   ✓ skills/ — ${skills.length} skills added (ace-*)`)
  }

  // agents 추가
  const agentsDir = path.join(claudeDir, 'agents')
  mkdirSafe(agentsDir)
  const packAgentsDir = path.join(ACE_ROOT, 'packs', pack, 'agents')
  if (fs.existsSync(packAgentsDir)) {
    const agents = fs.readdirSync(packAgentsDir).filter(f => f.endsWith('.md'))
    for (const agent of agents) {
      fs.copyFileSync(
        path.join(packAgentsDir, agent),
        path.join(agentsDir, agent)
      )
    }
    console.log(`   ✓ agents/ — ${agents.length} agents added`)
  }

  // templates 추가
  const templatesDir = path.join(CWD, '.ace', 'templates')
  mkdirSafe(templatesDir)
  const packTemplatesDir = path.join(ACE_ROOT, 'packs', pack, 'templates')
  if (fs.existsSync(packTemplatesDir)) {
    copyDirContents(packTemplatesDir, templatesDir)
    console.log('   ✓ templates/ — artifact templates added')
  }

  console.log(`\n✅ ${pack} pack added to ${projectName}`)
  console.log('   Claude Code를 재시작하면 새 스킬이 보입니다.\n')
}

// ─────────────────────────────────────────────
// start 명령 — 대화형 세팅 가이드
// ─────────────────────────────────────────────

async function start() {
  const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout,
  })

  const ask = (question) => new Promise((resolve) => {
    rl.question(question, (answer) => resolve(answer.trim()))
  })

  const projectName = path.basename(CWD)

  console.log('')
  console.log('═══ ACE Setup ═══')
  console.log(`프로젝트: ${projectName}`)
  console.log(`경로: ${CWD}`)
  console.log('')

  // 1. 스킬팩 선택
  console.log('1. 스킬팩 선택')
  console.log('   [1] dev — 코드 개발 (분석→설계→구현→검증)')
  console.log('   [2] biz — 사업 아이디어 (리서치→모델링→계획→판단)')
  const packChoice = await ask('   선택 (1): ')
  const pack = packChoice === '2' ? 'biz' : 'dev'
  console.log(`   → ${pack}`)
  console.log('')

  // 2. 기술 스택 선택 (dev만)
  let stack = 'nextjs-fastapi-pg'
  if (pack === 'dev') {
    console.log('2. 기술 스택 선택')
    console.log('   [1] nextjs-fastapi-pg  — Next.js + FastAPI + PostgreSQL')
    console.log('   [2] spring-vue-mssql   — Spring Boot + Vue.js + MSSQL')
    console.log('   [3] react-native-expo  — React Native + Expo')
    console.log('   [4] django-react-pg    — Django + React + PostgreSQL')
    const stackChoice = await ask('   선택 (1): ')
    const stackMap = { '1': 'nextjs-fastapi-pg', '2': 'spring-vue-mssql', '3': 'react-native-expo', '4': 'django-react-pg' }
    stack = stackMap[stackChoice] || 'nextjs-fastapi-pg'
    console.log(`   → ${stack}`)
    console.log('')
  }

  // 3. 모드 선택
  console.log(`${pack === 'dev' ? '3' : '2'}. 모드 선택`)
  console.log('   [1] solo — 혼자 작업 (간소화, 단계 스킵 가능)')
  console.log('   [2] team — 팀 협업 (역할분리, 산출물 표준화)')
  const modeChoice = await ask('   선택 (1): ')
  const mode = modeChoice === '2' ? 'team' : 'solo'
  console.log(`   → ${mode}`)
  console.log('')

  // 4. 이슈 트래커
  const stepNum = pack === 'dev' ? '4' : '3'
  console.log(`${stepNum}. 이슈 트래커 연동`)
  console.log('   [1] none   — 사용 안함')
  console.log('   [2] github — GitHub Issues')
  console.log('   [3] linear — Linear')
  console.log('   [4] jira   — Jira')
  console.log('   [5] redmine — Redmine')
  const trackerChoice = await ask('   선택 (1): ')
  const trackerMap = { '1': 'none', '2': 'github', '3': 'linear', '4': 'jira', '5': 'redmine' }
  const tracker = trackerMap[trackerChoice] || 'none'
  console.log(`   → ${tracker}`)
  console.log('')

  rl.close()

  // 확인
  console.log('─────────────────────────────')
  console.log(`  Pack:    ${pack}`)
  if (pack === 'dev') console.log(`  Stack:   ${stack}`)
  console.log(`  Mode:    ${mode}`)
  console.log(`  Tracker: ${tracker}`)
  console.log('─────────────────────────────')
  console.log('')

  // init 실행 (선택한 옵션으로)
  // args를 오버라이드
  args.length = 0
  args.push('init', '--pack', pack, '--stack', stack, '--mode', mode)
  init()
}

// ─────────────────────────────────────────────
// 메인
// ─────────────────────────────────────────────

if (command === 'init') {
  init()
} else if (command === 'start') {
  start().catch(console.error)
} else if (command === 'add-pack') {
  addPack()
} else {
  console.log(`
ACE — Agent-powered Code Engine

Usage:
  ace start                                        대화형 세팅 가이드
  ace init [--pack dev|biz] [--stack ...] [--mode solo|team]  직접 지정
